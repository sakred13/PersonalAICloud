# ─── Database ───────────────────────────────────────────────────────────────
DB_NAME=personalcloud
DB_USER=clouduser
# CHANGE THIS to a strong password before first run!
DB_PASSWORD=change_me_db_password_here

# ─── Auth ────────────────────────────────────────────────────────────────────
# CHANGE THIS to a long random string (e.g. openssl rand -hex 64)
JWT_SECRET=change_me_use_a_very_long_random_secret_at_least_64_chars

# ─── Server ──────────────────────────────────────────────────────────────────
# Port exposed on the host machine
PORT=80

# ─── Upload ──────────────────────────────────────────────────────────────────
# Max upload size in bytes. Default: 10 GB
MAX_FILE_SIZE=10737418240

# ─── Cookie security ──────────────────────────────────────────────────────────
# Set to 'true' ONLY if the app is served over HTTPS.
# Leave as 'false' for plain HTTP access (Tailscale IP, LAN, localhost).
# When 'true' on HTTP, browsers silently drop the session cookie → instant logout.
COOKIE_SECURE=false

# ─── AI Agent ─────────────────────────────────────────────────────────────────
# Base URL of your LM Studio OpenAI-compatible API (running on the host machine)
LLM_BASE_URL=http://host.docker.internal:1234/v1
# Model identifier exactly as shown in LM Studio's model panel
LLM_MODEL=google/gemma-4-e4b
# LM Studio accepts any non-empty string; leave as-is
LLM_API_KEY=lm-studio
# Cron schedule for the nightly image tagging job (default: 2 AM UTC)
AGENT_CRON=0 2 * * *
# UTC hour at which the batch job stops after finishing its current file (default: 4 AM UTC)
JOB_END_HOUR=4

